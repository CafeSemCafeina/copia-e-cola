{
  "name": "copia-e-cola",
  "version": "0.1.0",
  "private": true,
  "description": "Extensão local-first para guardar textos reutilizáveis por domínio.",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "package": "wxt zip",
    "test": "tsx --test tests/*.test.ts",
    "validate": "node scripts/validate-extension.mjs",
    "validate:boundaries": "node scripts/validate-repo-boundaries.mjs",
    "store:assets": "node scripts/generate-store-assets.mjs",
    "validate:publication": "node scripts/validate-publication-assets.mjs",
    "visual:snapshots": "node scripts/visual-snapshots.mjs",
    "chrome:smoke": "node scripts/chrome-smoke.mjs",
    "publish:ready": "npm run check && npm run chrome:smoke && npm run package",
    "check:all": "npm run publish:ready",
    "check": "npm run test && npm run build && npm run validate && npm run validate:publication && npm run validate:boundaries"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/chrome": "^0.1.43",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "playwright-core": "^1.61.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "wxt": "^0.20.26"
  },
  "dependencies": {
    "@fontsource/hanken-grotesk": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
